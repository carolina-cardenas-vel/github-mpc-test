{
  "name": "Python + Node",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "forwardPorts": [8000],
  "postCreateCommand": "test -f requirements.txt && pip install -r requirements.txt || echo 'No requirements.txt found'",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "ms-python.python",
        "ms-python.debugpy",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "chat.agent.enabled": true,
        "chat.mcp.enabled": true
      }
    }
  },
  "remoteUser": "vscode"
}